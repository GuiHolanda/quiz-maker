generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id             String          @id @default(cuid())
  name           String?
  email          String          @unique
  emailVerified  DateTime?
  image          String?
  password       String?
  accounts       Account[]
  sessions       Session[]
  certifications Certification[]
  questions      Question[]
  publicExams         PublicExam[]
  publicExamQuestions PublicExamQuestion[]
  usageLogs      UsageLog[]
  mockExams      MockExam[]
  mockAttempts   MockExamAttempt[]
  certSimulados        CertificationSimulado[]
  certSimuladoAttempts CertificationSimuladoAttempt[]
  plan                         String   @default("free")
  questionsGeneratedThisPeriod Int      @default(0)
  periodStartDate              DateTime @default(now())
  stripeCustomerId             String?
  stripeSubscriptionId         String?  @unique
  subscriptionStatus           String?
  customQuotaOverride          Int?
  createdAt      DateTime        @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Certification {
  id                  String               @id @default(cuid())
  label               String
  key                 String
  provider            String?
  totalQuestions      Int
  examDurationMinutes Int?
  passingScore        Float?
  topics              CertificationTopic[]
  userId              String?
  user                User?                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
}

model CertificationTopic {
  id              String        @id @default(cuid())
  name            String
  maxQuestions    Float
  minQuestions    Float
  certificationId String
  certification   Certification @relation(fields: [certificationId], references: [id], onDelete: Cascade)

  @@unique([certificationId, name])
}

model Question {
  id                 Int      @id @default(autoincrement())
  text               String
  correctCount       Int
  options            Option[]
  topic              String
  certificationTitle String
  difficulty         String
  topicSubarea       String?
  answer             Answer?
  createdAt          DateTime @default(now())
  userId             String?
  user               User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  certSimuladoQuestions CertificationSimuladoQuestion[]
}

model Option {
  id         Int      @id @default(autoincrement())
  questionId Int
  question   Question @relation(fields: [questionId], references: [id])
  label      String
  text       String
}

model Answer {
  id             Int           @id @default(autoincrement())
  questionId     Int           @unique
  question       Question      @relation(fields: [questionId], references: [id])
  correctOptions Json
  explanations   Explanation[]
}

model Explanation {
  id        Int      @id @default(autoincrement())
  answerId  Int
  answer    Answer   @relation(fields: [answerId], references: [id])
  label     String
  text      String
  createdAt DateTime @default(now())
}

model UsageLog {
  id           String   @id @default(cuid())
  userId       String
  action       String
  count        Int      @default(1)
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ExamBoard {
  id          String       @id @default(cuid())
  name        String       @unique
  fullName    String?
  publicExams PublicExam[]
}

model PublicExam {
  id                  String              @id @default(cuid())
  name                String
  role                String?
  year                Int?
  totalQuestions      Int
  examDurationMinutes Int?
  passingScore        Float?
  examBoardId         String
  examBoard           ExamBoard           @relation(fields: [examBoardId], references: [id])
  subjects            PublicExamSubject[]
  questions           PublicExamQuestion[]
  userId              String?
  mockExams           MockExam[]
  user                User?               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name, year])
}

model PublicExamSubject {
  id           String            @id @default(cuid())
  name         String
  minQuestions Float
  maxQuestions Float
  publicExamId String
  publicExam   PublicExam        @relation(fields: [publicExamId], references: [id], onDelete: Cascade)
  topics       PublicExamTopic[]
  questions    PublicExamQuestion[]

  @@unique([publicExamId, name])
}

model PublicExamTopic {
  id        String            @id @default(cuid())
  name      String
  subjectId String
  subject   PublicExamSubject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  questions PublicExamQuestion[]

  @@unique([subjectId, name])
}

model PublicExamQuestion {
  id             Int                @id @default(autoincrement())
  text           String
  correctCount   Int
  options        PublicExamOption[]
  publicExamName String
  examBoardName  String
  subject        String
  topic          String?
  difficulty     String
  answer         PublicExamAnswer?
  createdAt      DateTime           @default(now())
  userId         String?
  publicExamId   String?
  subjectId      String?
  topicId        String?
  mockExamQuestions MockExamQuestion[]
  publicExam     PublicExam?        @relation(fields: [publicExamId], references: [id], onDelete: SetNull)
  subjectRef     PublicExamSubject? @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  topicRef       PublicExamTopic?   @relation(fields: [topicId], references: [id], onDelete: SetNull)
  user           User?              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([publicExamId])
  @@index([subjectId])
  @@index([topicId])
}

model PublicExamOption {
  id         Int                @id @default(autoincrement())
  questionId Int
  question   PublicExamQuestion @relation(fields: [questionId], references: [id])
  label      String
  text       String
}

model PublicExamAnswer {
  id             Int                     @id @default(autoincrement())
  questionId     Int                     @unique
  question       PublicExamQuestion      @relation(fields: [questionId], references: [id])
  correctOptions Json
  explanations   PublicExamExplanation[]
}

model PublicExamExplanation {
  id        Int              @id @default(autoincrement())
  answerId  Int
  answer    PublicExamAnswer @relation(fields: [answerId], references: [id])
  label     String
  text      String
  createdAt DateTime         @default(now())
}

model MockExam {
  id           Int                     @id @default(autoincrement())
  name         String?
  publicExamId String
  userId       String?
  createdAt    DateTime                @default(now())
  publicExam   PublicExam              @relation(fields: [publicExamId], references: [id])
  user         User?                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  subjects     MockExamSubjectConfig[]
  questions    MockExamQuestion[]
  attempts     MockExamAttempt[]
}

model MockExamSubjectConfig {
  id            Int      @id @default(autoincrement())
  mockExamId    Int
  subjectName   String
  questionCount Int
  mockExam      MockExam @relation(fields: [mockExamId], references: [id], onDelete: Cascade)
}

model MockExamQuestion {
  id                   Int                     @id @default(autoincrement())
  mockExamId           Int
  publicExamQuestionId Int
  order                Int
  mockExam             MockExam                @relation(fields: [mockExamId], references: [id], onDelete: Cascade)
  publicExamQuestion   PublicExamQuestion      @relation(fields: [publicExamQuestionId], references: [id])
  attemptAnswers       MockExamAttemptAnswer[]
}

model MockExamAttempt {
  id         Int                     @id @default(autoincrement())
  mockExamId Int
  userId     String?
  startedAt  DateTime                @default(now())
  finishedAt DateTime?
  score      Int?
  mockExam   MockExam                @relation(fields: [mockExamId], references: [id], onDelete: Cascade)
  user       User?                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers    MockExamAttemptAnswer[]
}

model MockExamAttemptAnswer {
  id                 Int              @id @default(autoincrement())
  attemptId          Int
  mockExamQuestionId Int
  selectedOptions    String
  attempt            MockExamAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  mockExamQuestion   MockExamQuestion @relation(fields: [mockExamQuestionId], references: [id])
}

model CertificationSimulado {
  id        Int      @id @default(autoincrement())
  name      String?
  certKey   String
  userId    String?
  createdAt DateTime @default(now())
  user      User?                              @relation(fields: [userId], references: [id], onDelete: Cascade)
  topics    CertificationSimuladoTopicConfig[]
  questions CertificationSimuladoQuestion[]
  attempts  CertificationSimuladoAttempt[]

  @@index([userId])
}

model CertificationSimuladoTopicConfig {
  id            Int                   @id @default(autoincrement())
  simuladoId    Int
  topicName     String
  questionCount Int
  simulado      CertificationSimulado @relation(fields: [simuladoId], references: [id], onDelete: Cascade)

  @@index([simuladoId])
}

model CertificationSimuladoQuestion {
  id         Int                                  @id @default(autoincrement())
  simuladoId Int
  questionId Int
  order      Int
  simulado   CertificationSimulado                @relation(fields: [simuladoId], references: [id], onDelete: Cascade)
  question   Question                             @relation(fields: [questionId], references: [id])
  answers    CertificationSimuladoAttemptAnswer[]

  @@index([simuladoId])
}

model CertificationSimuladoAttempt {
  id         Int                                  @id @default(autoincrement())
  simuladoId Int
  userId     String?
  startedAt  DateTime                             @default(now())
  finishedAt DateTime?
  score      Int?
  simulado   CertificationSimulado                @relation(fields: [simuladoId], references: [id], onDelete: Cascade)
  user       User?                                @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers    CertificationSimuladoAttemptAnswer[]

  @@index([simuladoId])
  @@index([userId])
}

model CertificationSimuladoAttemptAnswer {
  id                 Int                           @id @default(autoincrement())
  attemptId          Int
  simuladoQuestionId Int
  selectedOptions    String
  attempt            CertificationSimuladoAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  simuladoQuestion   CertificationSimuladoQuestion @relation(fields: [simuladoQuestionId], references: [id], onDelete: Cascade)

  @@index([attemptId])
}

model AdminAuditLog {
  id        String   @id @default(cuid())
  adminId   String
  targetId  String
  action    String
  before    String
  after     String
  createdAt DateTime @default(now())

  @@index([adminId])
  @@index([targetId])
}
