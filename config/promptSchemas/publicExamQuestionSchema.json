{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "questions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "text": { "type": "string", "minLength": 20 },
          "correctCount": { "type": "integer", "minimum": 1, "maximum": 3 },
          "publicExamName": { "type": "string", "minLength": 3 },
          "examBoardName": { "type": "string", "minLength": 2 },
          "subject": { "type": "string", "minLength": 2 },
          "topic": { "type": "string" },
          "difficulty": { "type": "string", "enum": ["easy", "medium", "hard"] },
          "options": {
            "type": "object",
            "properties": {
              "A": { "type": "string", "minLength": 1 },
              "B": { "type": "string", "minLength": 1 },
              "C": { "type": "string", "minLength": 1 },
              "D": { "type": "string", "minLength": 1 },
              "E": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": false,
            "required": ["A", "B", "C", "D", "E"]
          }
        },
        "required": ["id", "text", "publicExamName", "examBoardName", "subject", "correctCount", "difficulty", "options"],
        "additionalProperties": false
      }
    }
  },
  "required": ["questions"],
  "additionalProperties": false
}
